# ==============================================================================
# Environment Variables Example
# ==============================================================================
# Copy this file to .env and fill in the keys/routes you need.
# The .env file contains secrets and must never be committed.
# ==============================================================================

# Windows UTF-8 safety switch.
PYTHONUTF8=1

# ==============================================================================
# Official Provider API Keys
# ==============================================================================

# OpenAI official API.
# Get a key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini official API.
# Get a key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# DeepSeek official API.
# Get a key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Doubao / Volcengine ARK API.
# Get a key from: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
DOUBAO_API_KEY=your-doubao-api-key-here

# Alibaba Qwen API.
# Get a key from: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=your-qwen-api-key-here

# ==============================================================================
# Optional DMX Proxy Routes
# ==============================================================================

# DMX overseas route.
DMX_OVERSEAS_API_KEY=your-dmx-overseas-api-key-here
DMX_OVERSEAS_BASE_URL=https://www.dmxapi.com/v1

# DMX domestic route.
DMX_DOMESTIC_API_KEY=your-dmx-domestic-api-key-here
DMX_DOMESTIC_BASE_URL=https://www.dmxapi.cn/v1

# ==============================================================================
# Where To Switch Runtime Settings
# ==============================================================================
# API keys and base URLs:
#   .env
#
# Stage1 provider/model:
#   src/shared/api_config.py -> STAGE1_PRESET, STAGE1_MODEL
#
# Stage2 network route:
#   src/shared/api_config.py -> STAGE2_NETWORK
#
# Stage2 evaluator ensemble:
#   src/shared/api_config.py -> STAGE2_EVAL_MODELS, STAGE2_MODEL_WEIGHTS
# ==============================================================================
